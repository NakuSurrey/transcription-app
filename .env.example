# ============================================
# SERVER MODE — which infrastructure to use
# ============================================
# "hpc"          = HPC cluster (manage server manually via sbatch/scancel)
# "digitalocean" = DigitalOcean GPU droplet (app controls start/stop)
SERVER_MODE=hpc

# ============================================
# Digital Ocean API — only needed if SERVER_MODE=digitalocean
# ============================================
DO_API_TOKEN=your_digital_ocean_api_token_here
DO_DROPLET_ID=your_droplet_id_here

# ============================================
# Server connection — where client sends audio
# ============================================
# For HPC mode: leave as localhost (tunnel handles routing)
# For DigitalOcean mode: set to your droplet's public IP
SERVER_IP=localhost
SERVER_PORT=8000
